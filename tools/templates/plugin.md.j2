## Clients
{{ render_api_entries(plugin.clients) }}

## Parameters
{% if plugin.parameters -%}
{%   for e in plugin.parameters -%}
{%-   set parts = [] -%}
{%-   if e.type_name -%}
{%-     set _ = parts.append("type: " ~ e.type_name) -%}
{%-   endif -%}
{%-   if e.default_value -%}
{%-     set _ = parts.append("default: `" ~ e.default_value ~ "`") -%}
{%-   endif -%}
{%-   set suffix = " [" ~ (parts | join(", ")) ~ "]" if parts else "" -%}
- `{{ e.name }}`{{ suffix }}{% if e.description %} - {{ e.description }}{% endif %}
{%   endfor -%}
{% else -%}
- None
{% endif %}

## MAVLink Subscriptions
{{ render_mavlink_entries(plugin.mavlink_subscriptions, "sub") }}

## MAVLink Publications
{{ render_mavlink_entries(plugin.mavlink_publications, "pub") }}
