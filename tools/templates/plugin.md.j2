{%- macro render_api_entries(entries) -%}
{%-   macro render_ros_type(type_name) -%}
{%-     set t = (type_name or "") | replace(" ", "") -%}
{%-     if "::msg::" in t -%}
{%-       set parts = t.split("::msg::", 1) -%}
{%-       set pkg = parts[0] -%}
{%-       set typ = parts[1].split("<", 1)[0] -%}
[{{ type_name }}](https://docs.ros.org/en/rolling/p/{{ pkg }}/msg/{{ typ }}.html)
{%-     elif "::srv::" in t -%}
{%-       set parts = t.split("::srv::", 1) -%}
{%-       set pkg = parts[0] -%}
{%-       set typ = parts[1].split("<", 1)[0] -%}
[{{ type_name }}](https://docs.ros.org/en/rolling/p/{{ pkg }}/srv/{{ typ }}.html)
{%-     elif "::action::" in t -%}
{%-       set parts = t.split("::action::", 1) -%}
{%-       set pkg = parts[0] -%}
{%-       set typ = parts[1].split("<", 1)[0] -%}
[{{ type_name }}](https://docs.ros.org/en/rolling/p/{{ pkg }}/action/{{ typ }}.html)
{%-     else -%}
{{ type_name or "<unknown>" }}
{%-     endif -%}
{%-   endmacro -%}
{%   for e in entries -%}
- `{{ e.name }}` ({{ render_ros_type(e.type_name) }}){% if e.description %} - {{ e.description }}{% endif %}
{%   else -%}
- None
{%   endfor -%}
{%- endmacro -%}
{%- macro render_mavlink_entries(entries, kind) -%}
{%   for s in entries -%}
{%-   set parts = [] -%}
{%-   set msg_label = s.message_name or "<unknown>" -%}
{%-   set msg_link = "https://mavlink.io/en/messages/" ~ s.dialect ~ ".html#" ~ msg_label if s.dialect and s.message_name else "" -%}
{%-   if kind == "pub" and s.argument -%}
{%-     set _ = parts.append("arg: `" ~ s.argument ~ "`") -%}
{%-   endif -%}
{%-   if kind == "sub" and s.handler -%}
{%-     set _ = parts.append("handler: " ~ s.handler) -%}
{%-   endif -%}
{%-   if s.dialect -%}
{%-     set _ = parts.append("dialect: " ~ s.dialect) -%}
{%-   endif -%}
{%-   if s.msg_id is not none -%}
{%-     set _ = parts.append("msg_id: " ~ s.msg_id) -%}
{%-   endif -%}
{%-   if s.msg_id_expr -%}
{%-     set _ = parts.append("id: `" ~ s.msg_id_expr ~ "`") -%}
{%-   endif -%}
{%-   set suffix = " [" ~ (parts | join(", ")) ~ "]" if parts else "" -%}
- {% if msg_link %}[`{{ msg_label }}`]({{ msg_link }}){% else %}`{{ msg_label }}`{% endif %}{{ suffix }}{% if s.description %} - {{ s.description }}{% endif %}
{%   else -%}
- None
{%   endfor -%}
{%- endmacro -%}
# {{ plugin.plugin }}

- File: `{{ shown_path }}`
- Class: `{{ plugin.class_name or "<unknown>" }}`
- Namespace: `{{ plugin.namespace or "<unknown>" }}`
{% if plugin.brief -%}
- Brief: {{ plugin.brief }}
{% endif %}

{% if plugin.description -%}
{{ plugin.description }}

{% endif -%}
